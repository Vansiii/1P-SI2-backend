# ============================================================================
# CONFIGURACIÓN PARA RAILWAY - MecánicoYa Backend
# ============================================================================
# IMPORTANTE: Configura estas variables en el panel de Railway
# Copia este archivo como .env.railway y completa con tus credenciales
# ============================================================================

# Database Configuration
# Railway te proporcionará una URL de base de datos si usas Railway Postgres
# O mantén tu conexión a Supabase (recomendado para tu caso)
DATABASE_URL=postgresql://user:password@host:port/database

# Supabase Configuration (Backend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database Pool Configuration
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Application Environment
ENVIRONMENT=production

# JWT Configuration - ⚠️ CAMBIAR OBLIGATORIAMENTE EN PRODUCCIÓN
# Genera una nueva clave secreta con: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-key-min-32-characters-long-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration - ⚠️ ACTUALIZAR CON TU URL DE FRONTEND
# Backend Railway + Frontend (actualizar con tu URL de frontend cuando lo despliegues)
CORS_ORIGINS=https://your-backend.railway.app,https://your-frontend.vercel.app,http://localhost:4200

# Email Provider Configuration
EMAIL_PROVIDER=api
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_FROM_NAME=Sistema de Emergencias Vehiculares

# Brevo SMTP Configuration
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your-brevo-smtp-user
BREVO_SMTP_PASSWORD=your-brevo-smtp-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=10

# Brevo API Configuration
BREVO_API_KEY=your-brevo-api-key
BREVO_API_URL=https://api.brevo.com/v3/smtp/email

# Frontend URL - ⚠️ ACTUALIZAR CON TU URL DE PRODUCCIÓN cuando despliegues el frontend
FRONTEND_URL=https://your-frontend.vercel.app

# Security Settings
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
OTP_EXPIRE_MINUTES=5
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Rate Limiting Settings
RATE_LIMIT_WHITELIST_IPS=
RATE_LIMIT_ADMIN_MULTIPLIER=3

# Gemini AI Configuration
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FALLBACK_MODELS=gemini-flash-lite-latest,gemini-2.5-flash,gemini-2.0-flash-lite
GEMINI_TIMEOUT_SECONDS=30
GEMINI_MAX_MEDIA_BYTES=4000000
GEMINI_PROMPT_VERSION=v1

# Firebase Configuration (Push Notifications)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
FIREBASE_PROJECT_ID=your-firebase-project-id
PUSH_NOTIFICATIONS_ENABLED=true

# Railway Specific (Railway las configura automáticamente)
# PORT=8000  # Railway asigna esto automáticamente
# HOST=0.0.0.0  # Railway requiere escuchar en todas las interfaces
