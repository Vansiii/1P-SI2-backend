# ============================================================================
# TEMPLATE PARA DESARROLLO LOCAL
# ============================================================================
# 
# INSTRUCCIONES PARA NUEVOS DESARROLLADORES:
# 1. Copia este archivo como .env: cp .env.development.template .env
# 2. Solicita al líder del equipo los valores reales para cada variable
# 3. Reemplaza los valores de ejemplo con los valores reales
# 4. Solicita también el archivo firebase-service-account.json
#
# ⚠️ IMPORTANTE: NO subas el archivo .env a GitHub
# ============================================================================

# ============================================================================
# 🔧 APPLICATION SETTINGS
# ============================================================================
ENVIRONMENT=development
DEBUG=true

# ============================================================================
# 🗄️ DATABASE CONFIGURATION (SUPABASE)
# ============================================================================
# Solicita esta URL al líder del equipo
# Formato: postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-1-sa-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=SOLICITAR_AL_EQUIPO

# Pool de conexiones (valores por defecto para desarrollo)
DB_POOL_SIZE=100
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ============================================================================
# 🔐 SUPABASE CONFIGURATION (BACKEND SERVICE ROLE)
# ============================================================================
# Solicita estos valores al líder del equipo
# Obtener de: Supabase Dashboard > Project Settings > API
SUPABASE_URL=SOLICITAR_AL_EQUIPO
SUPABASE_SERVICE_ROLE_KEY=SOLICITAR_AL_EQUIPO

# ============================================================================
# 🔑 JWT CONFIGURATION
# ============================================================================
# Solicita esta clave al líder del equipo (debe ser la misma para todo el equipo)
JWT_SECRET_KEY=SOLICITAR_AL_EQUIPO
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# 🌐 CORS CONFIGURATION (DESARROLLO LOCAL)
# ============================================================================
# Agrega tu IP local si vas a probar con móvil
# Ejemplo: http://localhost:4200,http://127.0.0.1:4200,http://192.168.1.5:4200
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:8000,http://127.0.0.1:8000

# ============================================================================
# 📧 EMAIL CONFIGURATION (BREVO)
# ============================================================================
# Solicita estas credenciales al líder del equipo
EMAIL_PROVIDER=api
EMAIL_FROM_ADDRESS=SOLICITAR_AL_EQUIPO
EMAIL_FROM_NAME=Sistema de Emergencias Vehiculares

# Brevo SMTP (si usas EMAIL_PROVIDER=smtp)
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=SOLICITAR_AL_EQUIPO
BREVO_SMTP_PASSWORD=SOLICITAR_AL_EQUIPO
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=10

# Brevo API (si usas EMAIL_PROVIDER=api) - RECOMENDADO
BREVO_API_KEY=SOLICITAR_AL_EQUIPO
BREVO_API_URL=https://api.brevo.com/v3/smtp/email

# Frontend URL (para links en emails)
FRONTEND_URL=http://localhost:4200

# ============================================================================
# 🔒 SECURITY SETTINGS
# ============================================================================
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
OTP_EXPIRE_MINUTES=5
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=5

# ============================================================================
# 🚦 RATE LIMITING
# ============================================================================
RATE_LIMIT_WHITELIST_IPS=
RATE_LIMIT_ADMIN_MULTIPLIER=3

# ============================================================================
# 🤖 GEMINI AI CONFIGURATION (OPCIONAL)
# ============================================================================
# Solicita esta API key al líder del equipo (opcional para desarrollo)
# Si no tienes, deja vacío y el sistema funcionará sin AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.0-flash-lite,gemini-2.0-flash
GEMINI_TIMEOUT_SECONDS=30
GEMINI_MAX_MEDIA_BYTES=4000000
GEMINI_PROMPT_VERSION=v1

# AI Analysis Timeout Configuration
AI_MAX_PROCESSING_SECONDS=60
AI_ASSIGNMENT_WAIT_TIMEOUT_SECONDS=120

# ============================================================================
# 📋 ASSIGNMENT CONFIGURATION
# ============================================================================
ASSIGNMENT_TIMEOUT_MINUTES=5
ASSIGNMENT_MAX_ATTEMPTS=5
ASSIGNMENT_RETRY_DELAY_SECONDS=10
ASSIGNMENT_TIMEOUT_HIGH_PRIORITY=3
ASSIGNMENT_TIMEOUT_MEDIUM_PRIORITY=5
ASSIGNMENT_TIMEOUT_LOW_PRIORITY=10

# ============================================================================
# 🔔 FIREBASE PUSH NOTIFICATIONS
# ============================================================================
# Solicita el archivo firebase-service-account.json al líder del equipo
# Guárdalo en la raíz del proyecto (1P-SI2-backend/)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
FIREBASE_PROJECT_ID=SOLICITAR_AL_EQUIPO
PUSH_NOTIFICATIONS_ENABLED=true

# ============================================================================
# 📝 NOTAS PARA DESARROLLO
# ============================================================================
#
# 1. CORS_ORIGINS: Si vas a probar con móvil, agrega tu IP local
#    Ejemplo: CORS_ORIGINS=http://localhost:4200,http://192.168.1.5:4200
#
# 2. Para encontrar tu IP local:
#    - Windows: ipconfig (busca "Dirección IPv4")
#    - Mac/Linux: ifconfig o ip addr
#
# 3. Firebase: El archivo JSON NO debe subirse a GitHub
#    Está protegido por .gitignore
#
# 4. GEMINI_API_KEY: Es opcional para desarrollo
#    Si no la tienes, el sistema funcionará sin análisis AI
#
# 5. Para ejecutar el servidor:
#    - Solo web: uvicorn app.main:app --reload
#    - Con móvil: uvicorn app.main:app --reload --host 0.0.0.0 --port 8000
#
# ============================================================================
