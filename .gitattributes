# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.ini text eol=lf
*.toml text eol=lf
*.cfg text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Environment files
.env* text eol=lf
*.example text eol=lf

# Documentation
*.rst text eol=lf
LICENSE text eol=lf
README* text eol=lf

# Declare files that will always have CRLF line endings on checkout
# (none for Python projects typically)

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.db binary
*.sqlite binary
*.sqlite3 binary
*.pyc binary
*.pyo binary
*.so binary
*.dll binary
*.exe binary
*.whl binary

# Python compiled files
*.pyc binary
*.pyo binary
*.pyd binary

# Archives
*.7z binary
*.jar binary
*.rar binary
*.tar binary
*.zip binary
*.gz binary
*.tgz binary
*.bz2 binary

# Fonts
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary

# Exclude files from export (git archive)
.gitattributes export-ignore
.gitignore export-ignore
.github export-ignore
tests/ export-ignore
.pytest_cache/ export-ignore
.coverage export-ignore
htmlcov/ export-ignore
*.pyc export-ignore
__pycache__/ export-ignore
.venv/ export-ignore
venv/ export-ignore
.env export-ignore
.env.* export-ignore
