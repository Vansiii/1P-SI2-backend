# Database Configuration
DATABASE_URL=postgresql://user:password@host:port/database

# Database Connection Pool Configuration
# ⚠️ OPTIMIZADO PARA ALTA CARGA - Fase 1 Real-Time System
# 
# Valores por defecto (desarrollo):
# - DB_POOL_SIZE=100: Conexiones permanentes en el pool
# - DB_MAX_OVERFLOW=20: Conexiones adicionales bajo demanda
# - DB_POOL_TIMEOUT=30: Segundos de espera para obtener conexión
# - DB_POOL_RECYCLE=3600: Reciclar conexiones cada hora
#
# Para producción con alta carga, considerar:
# - DB_POOL_SIZE=150-200
# - DB_MAX_OVERFLOW=30-50
#
# IMPORTANTE: Total máximo de conexiones = DB_POOL_SIZE + DB_MAX_OVERFLOW
# Asegúrate de que tu plan de Supabase soporte este número de conexiones
DB_POOL_SIZE=100
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Supabase Configuration (Backend Only - Service Role)
# Obtener de: https://app.supabase.com/project/_/settings/api
# IMPORTANTE: NUNCA exponer SUPABASE_SERVICE_ROLE_KEY al frontend
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-min-32-characters-long-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration
# Para desarrollo local y móvil, agregar tu IP local
# Ejemplo: CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://192.168.1.4:4200,http://192.168.1.4:8000
# Para desarrollo rápido (no recomendado en producción): CORS_ORIGINS=*
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# Email Provider Configuration
# Options: smtp, api
EMAIL_PROVIDER=smtp
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_FROM_NAME=Sistema de Emergencias Vehiculares

# Brevo SMTP Configuration (if EMAIL_PROVIDER=smtp)
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your-brevo-smtp-user
BREVO_SMTP_PASSWORD=your-brevo-smtp-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=10

# Brevo API Configuration (if EMAIL_PROVIDER=api)
BREVO_API_KEY=your-brevo-api-key
BREVO_API_URL=https://api.brevo.com/v3/smtp/email

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:4200

# Security Settings
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
OTP_EXPIRE_MINUTES=5
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=5

# Rate Limiting Settings
# Comma-separated list of IPs that bypass rate limiting (optional)
RATE_LIMIT_WHITELIST_IPS=127.0.0.1,::1
# Multiplier for admin rate limits (admins get X times more requests)
RATE_LIMIT_ADMIN_MULTIPLIER=3

# Gemini AI Configuration
# Leave GEMINI_API_KEY empty to disable automatic AI processing.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FALLBACK_MODELS=gemini-flash-lite-latest,gemini-2.5-flash,gemini-2.0-flash-lite
GEMINI_TIMEOUT_SECONDS=30
GEMINI_MAX_MEDIA_BYTES=4000000
GEMINI_PROMPT_VERSION=v1

# AI Analysis Slow Detection
# Threshold in seconds to detect slow AI analysis and emit warning event
AI_SLOW_THRESHOLD_SECONDS=15

# AI Analysis Timeout Configuration
# Maximum time in seconds for AI analysis processing before timeout
AI_MAX_PROCESSING_SECONDS=60
# Maximum time in seconds to wait for AI analysis before proceeding with assignment
AI_ASSIGNMENT_WAIT_TIMEOUT_SECONDS=120

# Firebase Configuration (Push Notifications)
# 
# OPCIÓN 1 (RECOMENDADA PARA RAILWAY/PRODUCCIÓN):
# Pegar el contenido completo del archivo JSON como string en una sola línea
# Ejemplo: FIREBASE_CREDENTIALS_JSON='{"type":"service_account","project_id":"..."}'
FIREBASE_CREDENTIALS_JSON=

# OPCIÓN 2 (DESARROLLO LOCAL):
# Path to Firebase service account JSON file (relative to project root)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# Firebase project ID (get from Firebase console)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Enable/disable push notifications
PUSH_NOTIFICATIONS_ENABLED=true

# Supabase Storage Configuration
# Obtener de: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
